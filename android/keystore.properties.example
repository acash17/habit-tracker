# Copy this file to keystore.properties (in the android/ folder) and fill in your values.
# DO NOT commit the real keystore.properties — it is gitignored.
#
# Generate the keystore once (back it up to 3 places):
#   keytool -genkey -v -keystore cadence-release.keystore -alias cadence \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Then move the .keystore file to a SAFE location (NOT inside the repo) and point storeFile to it.

storeFile=C:/Users/achau/secrets/cadence-release.keystore
storePassword=PUT_STORE_PASSWORD_HERE
keyAlias=cadence
keyPassword=PUT_KEY_PASSWORD_HERE
