# Copy this file to .env.local (gitignored) and fill in your Supabase project's values.
# Without these, the app runs in local-only mode — no auth, no cloud sync.
#
# Where to find them:
#   Supabase Dashboard → Project Settings → API
#     Project URL      → VITE_SUPABASE_URL
#     anon public key  → VITE_SUPABASE_ANON_KEY  (safe to expose; RLS protects rows)

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...   # public anon key, NOT the service-role key
